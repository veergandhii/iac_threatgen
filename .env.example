# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- NVIDIA Developer API (required) ---
# Create a key at https://build.nvidia.com/ -> your profile -> API Keys.
# Keys start with "nvapi-". The endpoint is OpenAI-compatible.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model + endpoint settings (single source of truth lives in
# src/iac_threatgen/constants.py; these env overrides are optional).
IAC_THREATGEN_MODEL=meta/llama-3.3-70b-instruct
IAC_THREATGEN_BASE_URL=https://integrate.api.nvidia.com/v1
IAC_THREATGEN_TEMPERATURE=0.2          # low = deterministic, grounded output

# --- GitHub (required only from Phase 4 onward, for the PR Agent) ---
# Fine-grained PAT scoped to the target repo with: Contents=Read/Write, Pull requests=Read/Write
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo
